# WRAITH v2.0 — Environment Variables
# Copy to .env and fill in your values

# AI Provider (optional - defaults to OpenRouter free tier)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Supabase (required for auth + storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# PayStack (required for payments)
PAYSTACK_SECRET_KEY=sk_live_your-key-here
PAYSTACK_PUBLIC_KEY=pk_live_yhere-key-here

# Web Server
WRAITH_SECRET_KEY=change-this-to-a-random-string
CIPHER_PORT=7734
